<html lang="en">
  <%- include("./partials/head.ejs") %>

  <body>
    <%- include("./partials/nav.ejs") %>

    <div class="create-message content">
      <a href="/categories/<%= category.id %>" class="back-link"
        >&larr; Back to <%= category.name %></a
      >
      <h2>Add a Movie to <%= category.name %></h2>
      <form action="/categories/<%= category.id %>/movies/new" method="POST">
        <label for="title">Title:</label>
        <input
          type="text"
          id="title"
          name="title"
          placeholder="e.g. Blade Runner"
          required
        />
        <label for="director">Director:</label>
        <input
          type="text"
          id="director"
          name="director"
          placeholder="e.g. Ridley Scott"
          required
        />
        <label for="year_released">Year Released:</label>
        <input
          type="number"
          id="year_released"
          name="year_released"
          placeholder="e.g. 1982"
          required
        />
        <button type="submit">Add Movie</button>
      </form>
    </div>

    <%- include("./partials/footer.ejs") %>
  </body>
</html>
