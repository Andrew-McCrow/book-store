<html lang="en">
  <%- include("./partials/head.ejs") %>

  <body>
    <%- include("./partials/nav.ejs") %>

    <div class="create-message content">
      <a href="/categories/<%= category.id %>" class="back-link"
        >&larr; Back to <%= category.name %></a
      >
      <h2>Edit Movie</h2>
      <form
        action="/categories/<%= category.id %>/movies/<%= movie.id %>/edit"
        method="POST"
      >
        <label for="title">Title:</label>
        <input
          type="text"
          id="title"
          name="title"
          value="<%= movie.title %>"
          required
        />
        <label for="director">Director:</label>
        <input
          type="text"
          id="director"
          name="director"
          value="<%= movie.director %>"
          required
        />
        <label for="year_released">Year Released:</label>
        <input
          type="number"
          id="year_released"
          name="year_released"
          value="<%= movie.year_released %>"
          required
        />
        <button type="submit">Save Changes</button>
      </form>
    </div>

    <%- include("./partials/footer.ejs") %>
  </body>
</html>
